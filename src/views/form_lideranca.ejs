<%- include("includes/header"); %>
<%- include("includes/navbar"); %>
   
<div class="row justify-content-center">   
    <div class="bg-light rounded-3 shadow-lg my-5 py-5 col-12 col-md-8 col-lg-6 border-top border-primary border-5">
        <% if (success && success.length > 0) { %>
            <% success.forEach(function(msg) { %>
                <div class="alert alert-success alert-dismissible fade show text-center my-2" role="alert">
                    <%= msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% }) %>
        <% } %>

        <% if (error && error.length > 0) { %>
            <% error.forEach(function(msg) { %>
                <div class="alert alert-danger alert-dismissible fade show text-center my-2" role="alert">
                    <%= msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% }) %>
        <% } %>


        <h2 class="text-center">Insira abaixo os dados da liderança.</h2>
        <form method="POST" action="/liderancas/new">                  
            <div id="mensagem_nome_vazio" class="alert alert-danger my-2 text-center" style="display: none">
                Campo nome não pode ser vazio.
            </div>
            <div id="mensagem_nome_apenas_letras" class="alert alert-danger my-2 text-center" style="display: none">
                Campo nome deve conter apenas letras.
            </div>
            <div class="form-floating my-4">
                <input type="text" class="form-control" id="nome_form" placeholder="Nome" name="nome" required>
                <label for="nome_form">Nome</label>
            </div>
            <div id="mensagem_contato_vazio" class="alert alert-danger text-center my-2" style="display: none">
                Contato não pode ser vazio.
            </div>
            <div id="mensagem_contato_formato" class="alert alert-danger text-center my-2" style="display: none">
                Contato deve seguir formato (XX) 9XXXX-XXXX.
            </div>                    
            <div class="form-floating my-4">
                <input type="text" class="form-control" id="contato_form" placeholder="contato" name="contato" required="Campo CONTATO não pode ser vazio.">
                <label for="contato_form">Contato</label>
            </div>     
            <div id="mensagem_data_formato" class="alert alert-danger text-center my-2" style="display: none">
                Data de nascimento deve seguir formato "dd/mm/yyyy".
            </div>      
            <div class="form-floating my-4">
                <input type="date" class="form-control" id="data_nascimento_form" placeholder="Nome" name="data_nascimento">
                <label for="nome_form">Data De Nascimento (Opcional)</label>
            </div>
            <div class="row justify-content-center ">     
                <button id="botao_salvar" type="submit" class="btn btn-primary btn-lg fw-bold w-25 btn-criar-lideranca mt-3"><i class="bi bi-save"></i> Salvar</button>
            </div>
        </form>
    </div>
</div>

<script src="/public/js/formLideranca.js"></script>

<%- include("includes/footer"); %>